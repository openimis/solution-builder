{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
    {
        "name": "docs",
        "program": "${workspaceFolder}/script/generate-confluence-aggregator.js",
        "request": "launch",
        "type": "node",
        "runtimeExecutable": "/usr/bin/node"
    },
    {
        "name": "Workbench",
        "program": "${workspaceFolder}/workbench.js",
        "request": "launch",
        "type": "node",
        "runtimeExecutable": "/usr/bin/node"
    },
      {
        "name": "Workbench publish",
        "program": "${workspaceFolder}/workbench.js",
        "args": ["--publish"],
        "request": "launch",
        "type": "node",
        "runtimeExecutable": "/usr/bin/node"
    },
      {
        "name": "Workbench docs",
        "program": "${workspaceFolder}/workbench.js",
        "args": ["--docs"],
        "request": "launch",
        "type": "node",
        "runtimeExecutable": "/usr/bin/node"
    },
      {
        "name": "Docs tree",
        "program": "${workspaceFolder}/script/dump-confluence-tree.js",
        "request": "launch",
        "type": "node",
        "runtimeExecutable": "/usr/bin/node"
    }
    ]
}